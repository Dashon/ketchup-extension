{
  "manifest_version": 3,
  "name": "Ketchup Capture",
  "description": "Manual DOM capture fallback for Ketchup — record user flows when the AI agent can't reach them.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://localhost:3003/*",
        "https://ketchup-webapp.vercel.app/*",
        "https://app.gitketchup.com/*"
      ],
      "js": ["src/auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/rrweb.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
